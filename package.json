{
  "name": "mcp-pet",
  "version": "1.0.0",
  "description": "MCP Desktop Pet",
  "author": "mangohow",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.mypet.coding-pet",
    "productName": "MC桌宠",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "mcp-server.js",
      "package.json",
      "renderer/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "assets/pet.json",
        "to": "pet.json"
      },
      {
        "from": "assets/spritesheet.webp",
        "to": "spritesheet.webp"
      }
    ],
    "win": {
      "target": "dir",
      "icon": null
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "cron-parser": "^5.5.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  }
}
